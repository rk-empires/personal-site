{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/gamification/**",
              "components/learning/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Playfair Display|Montserrat))/i]",
        "message": "Font not provided by the design system. Available: Playfair Display, Montserrat."
      },
      {
        "selector": "JSXOpeningElement[name.name='AnswerCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|label|state|onClick|style|key|ref|className|style|children)$/]",
        "message": "<AnswerCard> doesn't accept that prop. Declared props: children, label, state, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='AnswerCard'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:idle|selected|correct|incorrect|disabled)$/]",
        "message": "<AnswerCard> state must be one of 'idle' | 'selected' | 'correct' | 'incorrect' | 'disabled'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|dot|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, variant, size, dot, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|gold|gold-solid|success|error|warning|info|rookie|beginner|intermediate|advanced|expert|master)$/]",
        "message": "<Badge> variant must be one of 'default' | 'gold' | 'gold-solid' | 'success' | 'error' | 'warning' | 'info' | 'rookie' | 'beginner' | 'intermediate' | 'advanced' | 'expert' | 'master'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:xs|sm|md|lg)$/]",
        "message": "<Badge> size must be one of 'xs' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|disabled|loading|fullWidth|iconLeft|iconRight|onClick|type|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, disabled, loading, fullWidth, iconLeft, iconRight, onClick, type, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger|success)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger' | 'success'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:xs|sm|md|lg|xl)$/]",
        "message": "<Button> size must be one of 'xs' | 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|padding|radius|hoverable|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, variant, padding, radius, hoverable, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|gold|lesson|achievement|glass)$/]",
        "message": "<Card> variant must be one of 'default' | 'gold' | 'lesson' | 'achievement' | 'glass'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='padding'] > Literal[value!=/^(?:none|sm|md|lg|xl)$/]",
        "message": "<Card> padding must be one of 'none' | 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='radius'] > Literal[value!=/^(?:md|lg|xl|2xl|3xl)$/]",
        "message": "<Card> radius must be one of 'md' | 'lg' | 'xl' | '2xl' | '3xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='HeartIndicator'] > JSXAttribute > JSXIdentifier[name!=/^(?:current|max|size|style|key|ref|className|style|children)$/]",
        "message": "<HeartIndicator> doesn't accept that prop. Declared props: current, max, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='HeartIndicator'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<HeartIndicator> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|placeholder|value|onChange|type|disabled|error|hint|iconLeft|iconRight|size|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, placeholder, value, onChange, type, disabled, error, hint, iconLeft, iconRight, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:text|email|password|number|search|tel)$/]",
        "message": "<Input> type must be one of 'text' | 'email' | 'password' | 'number' | 'search' | 'tel'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Input> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LevelBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:level|showCrown|size|style|key|ref|className|style|children)$/]",
        "message": "<LevelBadge> doesn't accept that prop. Declared props: level, showCrown, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='LevelBadge'] > JSXAttribute[name.name='level'] > Literal[value!=/^(?:rookie|beginner|intermediate|advanced|expert|master)$/]",
        "message": "<LevelBadge> level must be one of 'rookie' | 'beginner' | 'intermediate' | 'advanced' | 'expert' | 'master'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LevelBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<LevelBadge> size must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PathNode'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|label|xp|icon|onClick|current|style|key|ref|className|style|children)$/]",
        "message": "<PathNode> doesn't accept that prop. Declared props: status, label, xp, icon, onClick, current, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PathNode'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:completed|active|locked)$/]",
        "message": "<PathNode> status must be one of 'completed' | 'active' | 'locked'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StreakBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:count|size|style|key|ref|className|style|children)$/]",
        "message": "<StreakBadge> doesn't accept that prop. Declared props: count, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StreakBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<StreakBadge> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='XPBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:current|max|label|showValues|size|animated|style|key|ref|className|style|children)$/]",
        "message": "<XPBar> doesn't accept that prop. Declared props: current, max, label, showValues, size, animated, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='XPBar'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<XPBar> size must be one of 'sm' | 'md' | 'lg'."
      }
    ]
  },
